#!/usr/bin/env ruby

require 'rubysketch/extension'
require 'reflex/packager'


profile = Reflex::Packager::Profile.new(
  pod:          'RubySketch',
  git:          'https://github.com/xord/rubysketch',
  version:      RubySketch::Extension.version,
  libraries:    %w[Xot Rucy Beeps Rays Reflex Processing RubySketch],
  extensions:   %w[beeps_ext rays_ext reflex_ext],
  config_files: %w[rubysketch.yml rubysketch.yaml],
  templates:    {'main.rb': <<~MAIN, 'rubysketch.yml': <<~CONFIG})
    require 'rubysketch'
    using RubySketch

    setup do
      setTitle '{{name}}'
    end

    draw do
      background 100
      text 'hello, world!', 100, 100
    end
  MAIN
    name: {{name}}
    version: 1.0.0
    #bundle_id: org.xord.rubysketch.example.{{name_id}}
    #icon: icon.png
  CONFIG

Reflex::Packager::CLI.new(profile).run ARGV.dup
